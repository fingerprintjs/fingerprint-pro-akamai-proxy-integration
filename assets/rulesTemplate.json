                "valueSource": "EXTRACT",
                "transform": "NONE",
                "variableName": "PMUSER_FPJS_AGENT_LOADER_VERSION",
                "extractLocation": "QUERY_STRING",
                "queryParameterName": "loaderVersion"
              }
            },
            {
              "name": "rewriteUrl",
              "options": {
                "behavior": "REWRITE",
                "targetUrl": "/web/v3/{{user.PMUSER_FPJS_PUBLIC_API_KEY}}/loader_v{{user.PMUSER_FPJS_AGENT_LOADER_VERSION}}.js?{{builtin.AK_QUERY}}"
              }
            }
          ],
          "criteria": [
            {
              "name": "queryStringParameter",
              "options": {
                "matchOperator": "EXISTS",
                "matchWildcardName": false,
                "matchCaseSensitiveName": true,
                "parameterName": "apiKey"
              }
            },
            {
              "name": "queryStringParameter",
              "options": {
                "matchOperator": "EXISTS",
                "matchWildcardName": false,
                "matchCaseSensitiveName": true,
                "parameterName": "loaderVersion"
              }
            }
          ],
          "criteriaMustSatisfy": "all",
          "comments": ""
        },
        {
